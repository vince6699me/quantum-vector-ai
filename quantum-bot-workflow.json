    {
      "parameters": {
        "text": "🔔 *New Group Message*\n\n*From:* {{ $json.userName }}\n*Group:* {{ $json.message.chat.title }}\n*Message:* {{ $json.message.text }}\n\nPlease review and respond if needed.",
        "additionalFields": {
