        }
      },
      "id": "notify-owner-group",
      "name": "Notify Owner - Group",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [850, 500],
      "credentials": {
        "telegramApi": ""
      }
    },
    {
      "parameters": {
        "jsCode": "const message = $input.first().json.messageText || '';\nconst lowerMessage = message.toLowerCase();\n\n// FAQ responses\nconst faqs = {\n  'what is quantumvector': 'QuantumVector AI provides AI solutions including chatbots, content generation, predictive analytics, and more. We help businesses integrate AI into their operations.',\n  'what services do you offer': 'We offer 11 AI services: Chatbots, Content Generation, Lead Generation, Custom LLM, Predictive Analytics, Document Intelligence, Voice AI, Computer Vision, AI Search, Consulting, and Customer Service Hub. Type /services for details.',\n  'how much': 'Our pricing starts at Ksh 129,870/month. Type /pricing for details.',\n  'price': 'Our pricing starts at Ksh 129,870/month. Type /pricing for details.',\n  'pricing': 'Our pricing starts at Ksh 129,870/month. Type /pricing for details.',\n  'how to book': 'Type /book to start the booking process.',\n  'contact': 'Email: quantumvectorllc@gmail.com, Phone: +1 (555) 012-3456. Type /contact for more info.',\n  'email': 'Our email is quantumvectorllc@gmail.com',\n  'phone': 'Our phone is +1 (555) 012-3456',\n  'location': 'Our office is in San Francisco, CA, USA',\n  'office': 'Our office is in San Francisco, CA, USA',\n  'delivery time': 'Timelines: Chatbots 2-4 weeks, Content 1-2 weeks, Lead Generation 3-4 weeks, Custom LLM 8-12 weeks.',\n  'timeline': 'Timelines: Chatbots 2-4 weeks, Content 1-2 weeks, Lead Generation 3-4 weeks, Custom LLM 8-12 weeks.',\n  'refund': 'We offer a 30-day money-back guarantee for all plans.',\n  'money back': 'We offer a 30-day money-back guarantee for all plans.',\n  'support': 'We offer email support (Starter), priority support (Professional), and 24/7 premium support (Enterprise).',\n  'payment': 'We accept M-Pesa, bank transfers, credit/debit cards (Visa, Mastercard). All prices include 16% VAT.',\n  'vat': 'Yes, all prices include 16% VAT as per Kenya Revenue Authority requirements.'\n};\n\n// Check for FAQ match\nlet matchedFaq = null;\nfor (const [key, value] of Object.entries(faqs)) {\n  if (lowerMessage.includes(key)) {\n    matchedFaq = value;\n    break;\n  }\n}\n\n// Check for booking intent\nconst bookingKeywords = ['book', 'interested', 'purchase', 'buy', 'order', 'hire', 'need'];\nconst hasBookingIntent = bookingKeywords.some(keyword => lowerMessage.includes(keyword));\n\n// Check for greetings\nconst greetings = ['hello', 'hi', 'hey', 'good morning', 'good afternoon', 'good evening'];\nconst isGreeting = greetings.some(greet => lowerMessage.includes(greet));\n\n// Check for email (potential booking info)\nconst hasEmail = message.includes('@');\n\nreturn {\n  json: {\n    matchedFaq,\n    hasBookingIntent,\n    hasEmail,\n    isGreeting,\n    originalMessage: message,\n    chatId: $input.first().json.chatId,\n    userId: $input.first().json.userId,\n    userName: $input.first().json.userName,\n    userUsername: $input.first().json.userUsername\n  }\n};"
      },
