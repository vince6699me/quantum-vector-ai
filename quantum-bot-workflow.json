      "parameters": {
        "text": "Great! Let's book a service for you. 📅\n\nPlease provide the following information:\n\n1️⃣ *Which service are you interested in?*\n   (e.g., Chatbots, Content Generation, Lead Generation)\n\n2️⃣ *Your company name*\n\n3️⃣ *Your email address*\n\n4️⃣ *Brief description of what you need*\n\nJust reply with this information and our team will contact you within 2 hours!",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
